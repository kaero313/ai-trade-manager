# AI-Trade-Manager local Linux always-on runtime template.
# Copy this file to .env.local and fill secrets on the operating machine.

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ai_trade_manager

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200

# Local admin protection
ADMIN_API_TOKEN=
ADMIN_BASIC_AUTH_USER=admin
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
ADMIN_BASIC_AUTH_HASH=

# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=

# Market/news providers
CRYPTOPANIC_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Upbit broker keys. Leave blank for paper/shadow operation.
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Slack emergency control
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=
SLACK_ALLOWED_USER_IDS=
SLACK_ALLOWED_CHANNEL_IDS=
SLACK_SIGNING_SECRET=

# Telegram emergency control
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local runtime
LOG_LEVEL=INFO
