# AI-Trade-Manager local Linux always-on runtime template.
# Copy this file to .env.local and fill secrets on the operating machine.

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ai_trade_manager

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200

# Local admin protection
ADMIN_API_TOKEN=
# Generate independently with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_REAUTH_SIGNING_SECRET=
# 독립적으로 생성하고 ADMIN_API_TOKEN 또는 ADMIN_REAUTH_SIGNING_SECRET과 재사용하지 않습니다.
RATE_LIMIT_SUBJECT_SECRET=
ADMIN_BASIC_AUTH_USER=admin
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
ADMIN_BASIC_AUTH_HASH=

# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=

# Market/news providers
CRYPTOPANIC_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Upbit broker keys. Leave blank for paper/shadow operation.
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Slack emergency control (Socket Mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USER_ID=
# 알림을 우선 전송할 채널 ID를 쉼표로 구분합니다. 첫 항목만 사용됩니다.
SLACK_TRADE_CHANNEL_IDS=

# Slack webhook notifications (포트폴리오 알림 발송 경로)
SLACK_WEBHOOK_URL=
SLACK_TIMEOUT=10

# Telegram emergency control
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_ID=

# Local runtime
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
